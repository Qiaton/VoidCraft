{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "output",
        "model": {
          "type": "minecraft:model",
          "model": "void_craft:item/coordinate_designator_output"
        }
      },
      {
        "when": "input",
        "model": {
          "type": "minecraft:model",
          "model": "void_craft:item/coordinate_designator_input"
        }
      },
      {
        "when": "unbind",
        "model": {
          "type": "minecraft:model",
          "model": "void_craft:item/coordinate_designator_unbind"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "void_craft:item/coordinate_designator_output"
    }
  }
}
