{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "cooldown_reduction",
        "model": {
          "type": "minecraft:model",
          "model": "void_craft:item/module_modifier_item_cooldown_reduction"
        }
      },
      {
        "when": "speed_boost",
        "model": {
          "type": "minecraft:model",
          "model": "void_craft:item/module_modifier_item_speed_boost"
        }
      },
      {
        "when": "active_duration",
        "model": {
          "type": "minecraft:model",
          "model": "void_craft:item/module_modifier_item_active_duration"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "void_craft:item/module_modifier_item_cooldown_reduction"
    }
  }
}
